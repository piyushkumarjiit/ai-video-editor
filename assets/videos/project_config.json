{
  "paths": {
    "video_dir": "./assets/videos",
    "input_dir": "./",
    "output_dir": "./",
    "clips_dir": "./ai_clips",
    "timeline": "./timeline_davinci_resolve.fcpxml",
    "video": null
  },
  "analysis": {
    "sample_interval": 2,
    "target_output_ratio": 0.15,
    "max_speed_multiplier": 8.0,
    "captioning": {
      "enabled": true,
      "model": "Qwen/Qwen2.5-VL-3B-Instruct",
      "max_length": 40,
      "min_length": 10,
      "num_beams": 4,
      "prompt": "Describe exactly what is visible. Identify model car parts, tools, hands, and materials. Avoid guessing; if uncertain, say 'unclear'.",
      "device": "cuda",
      "quantization": "4bit",
      "use_prompt_for_blip": false,
      "fallback_models": [],
      "max_image_size": 512
    }
  },
  "pipeline": {
    "dedupe": false,
    "hash_threshold": 6,
    "use_rendered": true,
    "exclude_boring": true,
    "skip_analysis": false,
    "skip_extract": false,
    "skip_export": false
  },
  "timeline": {
    "intro_clip": "./assets/Start-Intro-V3.mkv",
    "outro_clip": "./assets/Finish-Intro-V3.mkv",
    "exclude_boring": true,
    "include_classifications": ["interesting", "moderate"],
    "teaser_enabled": true,
    "teaser_max_duration": 45.0,
    "timeline_width": 3840,
    "timeline_height": 2160,
    "watermark_margin": 80,
    "watermark_scale": 0.19,
    "watermark_position_scale_with_zoom": true,
    "watermark_position_multiplier": 0.2436,
    "rotation_zoom": 1.78,
    "watermark_lane": 1,
    "main_video_lane": 0,
    "transition_duration": 1.0,
    "copy_intro_outro_to_clips_dir": false,
    "intro_outro_subdir": "_extras",
    "watermark": {
      "path": "./qr-code.jpg",
      "position": {
        "x": 3059.0,
        "y": -890.0
      },
      "transparency": 0.3
    },
    "background_music": {
      "folder": "./assets/music-background",
      "audio_lane": 2,
      "random_seed": null,
      "fade_duration": 3.0,
      "fade_silence_db": -60.0
    },
    "snippet_audio_volume_db": -96
  },
  "audio": {
    "background_music": {
      "folder": "./assets/music-background",
      "audio_lane": 2,
      "random_seed": null,
      "fade_duration": 3.0,
      "fade_silence_db": -60.0
    },
    "teaser_music": {
      "folder": "./assets/music-teaser",
      "audio_lane": 1,
      "random_seed": null,
      "fade_duration": 1.0,
      "fade_silence_db": -60.0
    },
    "snippet_audio_volume_db": -96
  }
}
